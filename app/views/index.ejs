<!DOCTYPE html>
<html>
  <head>
    <meta charset = "utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %></title>
    <link rel='stylesheet' href='dist/css/bootstrap.min.css' />
    <script src="https://d3js.org/d3.v6.js"></script>
  </head>

  <body>
  
    <div class="container mt-5">
      <div class="p-4 mb-4 bg-light border rounded">
        <h1><%= title %></h1>
        <p>Enter a student id to see the grade table.</p>
      </div>

      <div class="card">
        <div class="card-header">
          <button class="btn btn-link text-decoration-none p-0" type="button" data-bs-toggle="collapse" data-bs-target="#inputCard" aria-expanded="true" aria-controls="inputCard">
            <b>Searching Form</b>
          </button>
        </div>
        <div id="inputCard" class="collapse show">
          <div class="card-body">
          <form method="post" action="/">
            <div class="mb-3">
              <label for="student_info" class="form-label">Student ID or Name</label>
              <input type="text" class="form-control" id="student_info" name="student_info" required>
            </div>
            <button type="submit" class="btn btn-dark">Show grades</button>
          </form>
        </div>
        </div>
        
      </div>

      <div class="card">
        <div class="card-header">
          <button class="btn btn-link text-decoration-none p-0" type="button" data-bs-toggle="collapse"
            data-bs-target="#gradeGraph" aria-expanded="true" aria-controls="gradeGraph">
            <b>Average grade per quarter</b>
          </button>
        </div>
        <div id="gradeGraph" class="collapse show">
          <div class="card-body">
            <div class="dataviz"></div>
            </div>
      </div>

      <div class="card">
        <div class="card-header">
          <!-- Resulting data table -->
          <button class="btn btn-link text-decoration-none p-0" type="button" data-bs-toggle="collapse"
            data-bs-target="#gradeTable" aria-expanded="true" aria-controls="gradeTable">
            <b>Student <%= grades.length> 0 ? grades[0].student_id: 'no connection' %> - <%= grades.length> 0 ? grades[0].student:
                  'no connection' %> Grade Table</b>
          </button>
          </div>
          
        </div>
        <div id="gradeTable" class="collapse show">
          <div class="card-body">
          <!-- <p class="mb-0">Here comes the resulting data table</p> -->
        
        <table class="table table-striped table-bordered">
          <thead>
            <tr>
              <th>Year</th>
              <th>Quarter</th>
              <th>Course code</th>
              <th>Course name</th>
              <th>Grade</th>
            </tr>
          </thead>

          <tbody>
            <% grades.forEach(function(row) { %>
              <tr>
                <td>
                  <%= row.year %>
                </td>
                <td>
                  <%= row.quarter %>
                </td>
                <td>
                  <%= row.course_code %>
                </td>
                <td>
                  <%= row.course %>
                </td>
                <td>
                  <%= row.grade %>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
        </div>
        </div>
        
      </div>


    </div>
    <script src='dist/js/bootstrap.bundle.min.js'></script>
    <script>

      let chartData = [
      <% chartData.forEach(function(d, i){ %>
      {
        key: "<%= d.year %>-Q<%= d.quarter %>",
        value: <%= Number(d.avg_grade) %>,
      }<%= i <chartData.length-1?',':''%>

      <% }) %>
      ];

      // set the dimensions and margins of the graph
      const dataviz = document.querySelector(".dataviz");
      const cardWidth = dataviz.clientWidth;
      const margin = {top:10, right:30, bottom:80, left:40}, 
      width= cardWidth -margin.left-margin.right,
      height = 500 -margin.top-margin.bottom;

      // append the svg object to the body of the page
      const svg = d3.select(".dataviz").append("svg")
      .attr("width", width+margin.left+margin.right)
      .attr("height", height + margin.top + margin.bottom)
      .append("g")
      .attr("transform", `translate(${margin.left},${margin.top})`);

      //X axis
      const x=d3.scaleBand().range([0, width])
      .domain(chartData.map(d => d.key)).padding(0.2);
      svg.append("g")
      .attr("transform", `translate(0,${height})`)
      .call(d3.axisBottom(x))
      .selectAll("text")
      .attr("transform", "translate(-10,0)rotate(-45)")
      .style("text-anchor", "end")

      //Y axis
        const y = d3.scaleLinear()
        .domain([0, 10])
          .nice().range([height,0]);
        svg.append("g")
          .call(d3.axisLeft(y))

      //Bar
      svg.selectAll("bar").data(chartData).join("rect")
      .attr("x", d => x(d.key))
      .attr("width", x.bandwidth())
      .attr("fill", "#a5e976")
      // no bar at the beginning thus:
      .attr("height", d => height-y(0))
      .attr("y", d=>y(0))

      //Animation
      svg.selectAll("rect")
      .transition().duration(800)
      .attr("y", d => y(d.value))
      .attr("height", d=> height-y(d.value))
      .delay((d,i) => {console.log(i); return i*100})

      //Anchor
      svg.selectAll(".label")
      .data(chartData).join("text")
      .attr("class", "label")
      .attr("x", d=> x(d.key) + x.bandwidth()/2)
      .attr("y", d=>y(0)-10)
      .attr("text-anchor", "middle")
      .attr("fill", "black")
      .style("font-size", "12px")
      .text(d => d.value.toFixed(2))
      .transition()
      .duration(800)
      .attr("y", d=>y(d.value)-10)
      .delay((d,i)=>i*100);
      
    </script>
  </body>
</html>
